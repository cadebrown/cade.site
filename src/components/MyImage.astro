---
//https://docs.astro.build/en/guides/assets/
//import { Image } from "astro:assets";

import { Image } from "@astrojs/image/components";
import { tryImportAsset } from "../consts";
// TODO: resolve with markdown

// https://vkbansal.me/blog/resolving-images-astro-md/
const { src, alt, classes, caption = alt } = Astro.props;

//const { width, height } = Astro.props;

// attempt to import the asset, otherwise we will use the src
let asset = await tryImportAsset(src);
//console.log("ASSET", asset)

---

{
  asset && <Image src={asset} alt={alt} class={classes} /> || <img src={src} alt={alt} class={classes} />
}

<style>

  img {
    padding-top: 1.0em;
    padding-bottom: 1.0em;
  }
</style>
