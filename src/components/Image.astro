---
const { src, caption, classes } = Astro.props;
---

<figure class={classes}>
  <img src={src} alt={"image: " + src} />
  <figcaption>{caption}</figcaption>
</figure>
<style>


  figure {
    margin: 1em;
  }

  figcaption {
    margin: 0 0.25em;
  }

  img {
    margin-top: 0 !important;
    margin-bottom: 0.5em !important;
  }
  /* named styles */
  /*  */
  @media only screen and (min-width: 768px) {
    .float-right {
      float: right;
      max-width: 40%;
      padding-left: 0.5em;
    }
    .float-left {
      float: left;
      max-width: 40%;
      padding-right: 0.5em;
    }
  }

</style>
